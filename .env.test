// .env.test
NODE_ENV=test
PORT=5000

# Database (test DB)
DB_NAME=yobante_boutique_test
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost

# JWT
JWT_SECRET=test-secret-key-do-not-use-in-production-1234567890
JWT_REFRESH_SECRET=test-refresh-secret-key-different-1234567890
JWT_RESET_SECRET=test-reset-secret-key-different-9876543210
JWT_EXPIRES_IN=1h

# CORS
CORS_ORIGIN=http://localhost:3000

# Email
RESEND_API_KEY=test-resend-key

# Cloudinary
CLOUDINARY_CLOUD_NAME=test-cloud
CLOUDINARY_API_KEY=test-api-key
CLOUDINARY_API_SECRET=test-api-secret
