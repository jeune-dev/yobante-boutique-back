# ═══════════════════════════════════════════════════════════════════════════
# Yobante Boutique Backend - Configuration Environnement
# ═══════════════════════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Base de données PostgreSQL ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=yobante_boutique
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_SSL=false
# DB_SSL=true  # Activer en production

# ─── JWT - Secrets d'authentification ─────────────────────────────────────
# ⚠️  IMPORTANT: Les trois secrets DOIVENT être différents
# Générer avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

JWT_SECRET=change_me_with_secure_random_secret
JWT_REFRESH_SECRET=change_me_with_different_secure_random_secret
JWT_RESET_SECRET=change_me_with_another_different_secure_random_secret
JWT_EXPIRES_IN=1h

# ─── CORS - Origins autorisées ────────────────────────────────────────────
# Format: liste séparée par virgules (pas d'espaces)
# Ex: http://localhost:3000,https://app.yobante.com

CORS_ORIGIN=http://localhost:3000

# ⚠️  JAMAIS CORS_ORIGIN=* en production!

# ─── Cloudinary - Image Upload ───────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email - Resend Service ──────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
MAIL_FROM=noreply@yobante.com

# ─── Admin Initial (Seeder) ──────────────────────────────────────────────
# ⚠️  CHANGER avant production!

ADMIN_EMAIL=admin@yobante.com
ADMIN_PASSWORD=Admin1234!
ADMIN_NOM=Admin
ADMIN_PRENOM=Yobante

# ─── Frais de livraison par défaut (en cas d'absence dans la table FraisLivraison) ──
FRAIS_LIVRAISON_DEFAUT=15

# ─── Pool PostgreSQL ──────────────────────────────────────────────────────────
DB_POOL_MAX=20
DB_POOL_MIN=2

# ─── Versioning API ───────────────────────────────────────────────────────────
# Toutes les routes sont maintenant sous /api/v1/*

# ─── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=debug

# ═══════════════════════════════════════════════════════════════════════════
# CHECKLIST DE DÉPLOIEMENT PRODUCTION
# ═══════════════════════════════════════════════════════════════════════════
#
# ☐ NODE_ENV=production
# ☐ JWT_SECRET, JWT_REFRESH_SECRET, JWT_RESET_SECRET = valeurs fortes & uniques
# ☐ ADMIN_EMAIL et ADMIN_PASSWORD changés (pas les valeurs par défaut)
# ☐ DB_SSL=true et DB_HOST pointant vers DB prod
# ☐ CORS_ORIGIN = domaines réels (jamais *)
# ☐ CLOUDINARY_* et RESEND_API_KEY configurés
# ☐ .env.example commité, .env NON commité
# ☐ Variables d'environnement définis sur le serveur (Render, Railway, etc)
#
# ═══════════════════════════════════════════════════════════════════════════
